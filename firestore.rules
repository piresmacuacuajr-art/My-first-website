rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access to properties, testimonials, and blog posts
    match /properties/{property} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    match /testimonials/{testimonial} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    match /blogPosts/{post} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    match /appConfig/{config} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Allow anyone to create an inquiry, but only admins can read them
    match /inquiries/{inquiry} {
      allow create: if true;
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
